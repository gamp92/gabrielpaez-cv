---
import { SKILLS } from '../data.js';
---

<section id="skills" class="px-6 md:px-12 lg:px-16 py-12 md:py-20 max-w-6xl mx-auto bg-bone-100/50">
  <div class="reveal mb-10 md:mb-12 flex items-baseline justify-between">
    <h2 class="font-mono text-headline text-ink">Skills</h2>
    <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted">/ stack</div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
    {SKILLS.map((group, idx) => (
      <div class="reveal" data-delay={Math.min(idx + 1, 4)}>
        <h3 class="font-mono text-xs uppercase tracking-wider text-ink mb-3 pb-2 border-b border-ink/15">
          {group.category}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {group.items.map((item) => (
            <span class="font-mono text-xs px-2.5 py-1.5 bg-bone-50 border border-ink/15 text-ink-soft hover:bg-ink hover:text-bone-50 hover:border-ink transition-colors duration-200">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
