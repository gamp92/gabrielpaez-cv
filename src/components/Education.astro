---
import { EDUCATION, CERTIFICATIONS, LANGUAGES } from '../data.js';
---

<section id="education" class="px-6 md:px-12 lg:px-16 py-12 md:py-20 max-w-6xl mx-auto bg-bone-100/50">
  <div class="reveal mb-10 md:mb-12">
    <h2 class="font-mono text-headline text-ink">Education & Credentials</h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Education (2 cols) -->
    <div class="lg:col-span-2 space-y-8">
      <h3 class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted">/ academic</h3>
      {EDUCATION.map((edu, idx) => (
        <div class="reveal" data-delay={Math.min(idx + 1, 4)}>
          <div class="font-mono text-xs text-ink-muted mb-1">{edu.period}</div>
          <h4 class="font-mono text-base font-semibold text-ink mb-1">{edu.degree}</h4>
          <div class="font-mono text-xs text-signal-dark mb-3">{edu.institution}</div>
          <p class="text-sm text-ink-soft leading-relaxed">{edu.detail}</p>
        </div>
      ))}
    </div>

    <!-- Sidebar: certs + langs -->
    <div class="space-y-10">
      <div class="reveal">
        <h3 class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted mb-4">/ certifications</h3>
        <ul class="space-y-2">
          {CERTIFICATIONS.map((cert) => (
            <li>
              <div class="font-mono text-sm text-ink">{cert.name}</div>
              <div class="font-mono text-xs text-ink-faint">{cert.issuer}</div>
            </li>
          ))}
        </ul>
      </div>

      <div class="reveal" data-delay="1">
        <h3 class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted mb-4">/ languages</h3>
        <ul class="space-y-2">
          {LANGUAGES.map((lang) => (
            <li>
              <div class="font-mono text-sm text-ink">{lang.name}</div>
              <div class="font-mono text-xs text-ink-faint">{lang.level}</div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
