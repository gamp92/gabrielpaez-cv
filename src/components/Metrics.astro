---
import { METRICS } from '../data.js';
---

<section class="px-6 md:px-12 lg:px-16 py-12 md:py-16 max-w-6xl mx-auto">
  <div class="reveal mb-8">
    <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted">/ impact</div>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
    {METRICS.map((metric, idx) => (
      <div
        class="reveal border border-ink/15 bg-bone-100/40 p-5 md:p-6 hover:bg-bone-100 hover:border-ink/40 transition-colors duration-300"
        data-delay={Math.min(idx + 1, 4)}
      >
        <div class="font-mono text-3xl md:text-4xl font-semibold text-ink mb-2 tracking-tight">
          {metric.value}
        </div>
        <div class="font-mono text-[10px] uppercase tracking-wider text-ink-muted mb-1">
          {metric.label}
        </div>
        <div class="font-mono text-xs text-ink-faint leading-snug">
          {metric.detail}
        </div>
      </div>
    ))}
  </div>
</section>
