---
import { EXPERIENCE } from '../data.js';
---

<section id="experience" class="px-6 md:px-12 lg:px-16 py-12 md:py-20 max-w-6xl mx-auto">
  <div class="reveal mb-10 md:mb-12 flex items-baseline justify-between">
    <h2 class="font-mono text-headline text-ink">Experience</h2>
    <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted">/ {String(EXPERIENCE.length).padStart(2, '0')} roles</div>
  </div>

  <div class="space-y-12 md:space-y-16">
    {EXPERIENCE.map((job, idx) => (
      <article class="reveal grid grid-cols-1 md:grid-cols-[180px_1fr] gap-4 md:gap-10 group" data-delay={Math.min(idx + 1, 4)}>
        <!-- Left rail: period + location -->
        <div class="md:pt-1">
          <div class="font-mono text-xs text-ink-muted mb-1">{job.period}</div>
          <div class="font-mono text-[11px] text-ink-faint">{job.location}</div>
        </div>

        <!-- Right: role + bullets + stack -->
        <div class="border-l-2 border-ink/10 pl-5 md:border-l-0 md:pl-0 md:border-t-2 md:pt-5 group-hover:border-ink/40 transition-colors duration-300">
          <h3 class="font-mono text-base md:text-lg font-semibold text-ink mb-1">{job.role}</h3>
          <div class="font-mono text-xs text-signal-dark mb-4">@ {job.company}</div>

          <ul class="space-y-2.5 mb-5">
            {job.bullets.map((bullet) => (
              <li class="text-sm text-ink-soft leading-relaxed flex gap-3">
                <span class="text-ink-faint mt-1.5 flex-shrink-0">▪</span>
                <span set:html={bullet} />
              </li>
            ))}
          </ul>

          {job.stack && job.stack.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {job.stack.map((tech) => (
                <span class="font-mono text-[10px] px-2 py-1 bg-bone-100 border border-ink/10 text-ink-muted">
                  {tech}
                </span>
              ))}
            </div>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
