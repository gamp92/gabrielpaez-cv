---
import { PROJECTS, SITE } from '../data.js';
---

<section id="projects" class="px-6 md:px-12 lg:px-16 py-12 md:py-20 max-w-6xl mx-auto">
  <div class="reveal mb-10 md:mb-12 flex items-baseline justify-between">
    <h2 class="font-mono text-headline text-ink">Featured Work</h2>
    <a
      href={SITE.github}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted hover:text-ink transition-colors"
    >
      / view all on github →
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {PROJECTS.map((project, idx) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="reveal block border border-ink/15 p-5 md:p-6 hover:border-ink hover:bg-bone-100/50 transition-all duration-200 group"
        data-delay={Math.min(idx + 1, 4)}
      >
        <div class="flex items-start justify-between mb-3">
          <h3 class="font-mono text-sm font-semibold text-ink group-hover:text-signal-dark transition-colors">
            {project.name}
          </h3>
          <span class="font-mono text-ink-faint text-xs group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">↗</span>
        </div>

        <p class="text-xs text-ink-soft leading-relaxed mb-4 min-h-[3rem]">
          {project.description}
        </p>

        <div class="flex flex-wrap gap-1">
          {project.stack.map((tech) => (
            <span class="font-mono text-[10px] text-ink-muted">
              {tech}
            </span>
          )).reduce((acc, el, i) => {
            if (i > 0) acc.push(<span class="font-mono text-[10px] text-ink-faint">·</span>);
            acc.push(el);
            return acc;
          }, [])}
        </div>
      </a>
    ))}
  </div>

  <div class="reveal mt-8">
    <p class="font-mono text-xs text-ink-faint italic">
      // More projects in active development — including <span class="text-ink-muted">cheme-calc</span>, an open-source chemical engineering calculator suite.
    </p>
  </div>
</section>
