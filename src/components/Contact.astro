---
import { SITE } from '../data.js';
---

<section id="contact" class="px-6 md:px-12 lg:px-16 py-16 md:py-24 max-w-6xl mx-auto">
  <div class="reveal max-w-3xl">
    <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-muted mb-4">/ contact</div>
    <h2 class="text-display font-mono mb-6 text-ink">
      Let's talk<span class="text-signal">.</span>
    </h2>
    <p class="text-base md:text-lg text-ink-soft leading-relaxed mb-10 max-w-xl">
      Open to senior QA / QA Lead / Engineering Manager roles — remote-first, with availability for UK, EU, and US time zones.
      Reach out directly:
    </p>

    <div class="flex flex-col sm:flex-row gap-3">
      <button
        id="copy-email-btn-2"
        class="inline-flex items-center justify-between gap-4 font-mono text-sm px-5 py-4 bg-ink text-bone-50 hover:bg-signal-dark transition-colors duration-200 group"
        data-email={SITE.email}
      >
        <span id="copy-email-text-2">{SITE.email}</span>
        <span class="text-bone-50/60 group-hover:text-bone-50 text-xs">[ copy ]</span>
      </button>
      <a
        href={SITE.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-between gap-4 font-mono text-sm px-5 py-4 border border-ink text-ink hover:bg-ink hover:text-bone-50 transition-colors duration-200"
      >
        <span>LinkedIn</span>
        <span class="text-ink-muted group-hover:text-bone-50 text-xs">↗</span>
      </a>
    </div>
  </div>
</section>

<footer class="px-6 md:px-12 lg:px-16 py-8 max-w-6xl mx-auto border-t border-ink/10">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 font-mono text-xs text-ink-faint">
    <div>
      © {new Date().getFullYear()} {SITE.name}. Built with Astro.
    </div>
    <div class="flex gap-4">
      <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">LinkedIn</a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">GitHub</a>
      <button id="copy-email-btn-3" class="hover:text-ink transition-colors" data-email={SITE.email}>
        <span id="copy-email-text-3">Email</span>
      </button>
    </div>
  </div>
</footer>

<script>
  // Wire up the additional copy-email buttons
  document.querySelectorAll('[id^="copy-email-btn-"]').forEach((btn) => {
    const id = btn.id.split('btn-')[1];
    const txtEl = document.getElementById('copy-email-text-' + id);
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const email = btn.getAttribute('data-email');
      if (!email) return;
      try {
        await navigator.clipboard.writeText(email);
        if (txtEl) {
          const original = txtEl.textContent;
          txtEl.textContent = '✓ Copied';
          setTimeout(() => { txtEl.textContent = original; }, 2200);
        }
      } catch (err) {
        if (txtEl) txtEl.textContent = email;
      }
    });
  });
</script>
